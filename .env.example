# API_KEY: clave requerida para las llamadas a la API de tu proyecto
# AI Studio inyecta esto automáticamente en tiempo de ejecución desde los secretos del usuario.
# Configura tu clave desde el panel de Secrets en la UI de AI Studio.
API_KEY="TU_CLAVE_REAL_DEL_PROYECTO"

# APP_URL: la URL donde se aloja este applet o aplicación web.
# AI Studio inyecta esto automáticamente en tiempo de ejecución con la URL del servicio de Cloud Run.
# Se utiliza para enlaces internos, callbacks y endpoints de API.
APP_URL="https://"
